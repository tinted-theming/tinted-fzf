# Template author: Tinted Theming (https://github.com/tinted-theming)

_gen_fzf_default_opts() {

local color00='#242015'
local color01='#3a3124'
local color02='#4d3f32'
local color03='#5f4e41'
local color04='#b8a58c'
local color05='#d2c3a4'
local color06='#ebe0bb'
local color07='#f1e9d0'
local color08='#db930d'
local color09='#ebe0bb'
local color0A='#a82d56'
local color0B='#7a7653'
local color0C='#db930d'
local color0D='#c1666b'
local color0E='#91506c'
local color0F='#61a0a8'

export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS"\
" --color=bg+:$color01,bg:$color00,spinner:$color0C,hl:$color0D"\
" --color=fg:$color04,header:$color0D,info:$color0A,pointer:$color0C"\
" --color=marker:$color0C,fg+:$color06,prompt:$color0A,hl+:$color0D"

}

_gen_fzf_default_opts
