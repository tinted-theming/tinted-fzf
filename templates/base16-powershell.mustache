$_non_color = ($ENV:FZF_DEFAULT_OPTS -split ' ' | Where-Object { $_ -notmatch '^--color=' }) -join ' '
$ENV:FZF_DEFAULT_OPTS = @"
$_non_color --color=bg+:#{{base01-hex}},bg:#{{base00-hex}},spinner:#{{base0C-hex}},hl:#{{base0D-hex}}
 --color=fg:#{{base04-hex}},header:#{{base0D-hex}},info:#{{base0A-hex}},pointer:#{{base0C-hex}}
 --color=marker:#{{base0C-hex}},fg+:#{{base06-hex}},prompt:#{{base0A-hex}},hl+:#{{base0D-hex}}
"@
